{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/ai-data-automation-workflow-v0.1.json",
  "title": "AI Data Automation Studio Workflow Definition",
  "type": "object",
  "required": [
    "schema_version",
    "workflow_id",
    "name",
    "status",
    "owner",
    "trigger",
    "inputs",
    "steps",
    "outputs",
    "runtime",
    "governance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "archived"
      ]
    },
    "owner": {
      "type": "object",
      "required": [
        "user_id",
        "workspace_id"
      ],
      "properties": {
        "user_id": {
          "type": "string"
        },
        "workspace_id": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "trigger": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "manual_upload",
            "manual_existing_asset",
            "schedule",
            "webhook",
            "connector_event",
            "api"
          ]
        },
        "required_inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allow_rerun": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input"
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/output"
      }
    },
    "runtime": {
      "$ref": "#/$defs/runtime"
    },
    "governance": {
      "$ref": "#/$defs/governance"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "input": {
      "type": "object",
      "required": [
        "input_id",
        "name",
        "kind",
        "format",
        "required"
      ],
      "properties": {
        "input_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "file",
            "dataset",
            "connector",
            "parameter",
            "reference_table"
          ]
        },
        "format": {
          "type": "string",
          "enum": [
            "csv",
            "xlsx",
            "json",
            "parquet",
            "sql_table",
            "api_response",
            "unknown"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "schema": {
          "type": "object",
          "additionalProperties": true
        },
        "source": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "step": {
      "type": "object",
      "required": [
        "step_id",
        "type",
        "name",
        "enabled",
        "input_refs",
        "output_ref",
        "params"
      ],
      "properties": {
        "step_id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "input_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "output_ref": {
          "type": "string"
        },
        "params": {
          "type": "object",
          "additionalProperties": true
        },
        "ai": {
          "type": "object",
          "additionalProperties": true
        },
        "on_error": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "output": {
      "type": "object",
      "required": [
        "output_id",
        "type",
        "name"
      ],
      "properties": {
        "output_id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "clean_file",
            "exception_report",
            "run_summary",
            "documentation",
            "database_table",
            "power_bi",
            "notification",
            "api_call"
          ]
        },
        "name": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "destination": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "runtime": {
      "type": "object",
      "required": [
        "execution_mode",
        "data_plane",
        "storage_provider",
        "secrets_provider"
      ],
      "properties": {
        "execution_mode": {
          "type": "string",
          "enum": [
            "vendor_saas",
            "customer_agent",
            "customer_cloud",
            "self_hosted"
          ]
        },
        "data_plane": {
          "type": "string"
        },
        "storage_provider": {
          "type": "string"
        },
        "secrets_provider": {
          "type": "string"
        },
        "worker_pool": {
          "type": "string"
        },
        "max_runtime_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "max_input_size_mb": {
          "type": "integer",
          "minimum": 1
        },
        "retry_policy": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "governance": {
      "type": "object",
      "properties": {
        "sensitivity": {
          "type": "string",
          "enum": [
            "public",
            "internal",
            "confidential",
            "restricted"
          ]
        },
        "requires_approval_for_external_outputs": {
          "type": "boolean"
        },
        "allow_ai_generated_steps": {
          "type": "boolean"
        },
        "require_review_for_destructive_steps": {
          "type": "boolean"
        },
        "retention_days": {
          "type": "integer",
          "minimum": 0
        },
        "audit_level": {
          "type": "string",
          "enum": [
            "minimal",
            "standard",
            "strict"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}