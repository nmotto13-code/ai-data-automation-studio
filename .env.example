# --- Database ---
# Railway injects DATABASE_URL automatically when you add a Postgres service.
# For local dev, leave as SQLite default:
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# --- Storage ---
# Leave S3_* blank to use local filesystem storage (local dev only).
# Set all three for production (Cloudflare R2, AWS S3, or Backblaze B2).
STORAGE_ROOT=./storage
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Cloudflare R2 endpoint: https://<account_id>.r2.cloudflarestorage.com
# AWS S3: leave blank
S3_ENDPOINT_URL=
S3_REGION=auto

# --- App ---
STUB_WORKSPACE_ID=00000000-0000-0000-0000-000000000001
CORS_ORIGINS=["http://localhost:3000"]
MAX_UPLOAD_SIZE_BYTES=104857600

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
